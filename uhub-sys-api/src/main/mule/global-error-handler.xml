	<sub-flow name="global-error-handling-subFlow" doc:id="f795667f-f2e3-4c65-bf21-52c8b35b1d7c" >
		<ee:transform doc:name="Init variables" doc:id="387ee2b7-db57-4d8f-96e0-564d3ce73ca2" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/java
---
if(vars.errorDescription?)
	vars.errorDescription
else
	error.exception.detailMessage]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<ee:transform doc:name="Error Response" doc:id="a98a2e5c-0dbf-47b0-8c24-7424590025a6" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
	"code":vars.httpStatus,
	"message":if(vars.errorMessage != null) vars.errorMessage else (error.errorType.identifier),
	"description":if(vars.errorDescription != null) vars.errorDescription else error.description,
	"dateTime":now() as String {format : "YYYY-MM-dd-HH-mm-ss"},
	"transactionId":vars.transactionId
	
}]]></ee:set-payload>
			</ee:message>
			<ee:variables >
				<ee:set-variable variableName="httpStatus" ><![CDATA[vars.httpStatus]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<logger level="INFO" doc:name="Error Logger" doc:id="13851733-ba88-4acf-9b6e-837548041efa" message="Trasaction [#[vars.transactionId]] " />
	</sub-flow>
</mule>
